GEMINI_API_KEY="your_gemini_api_key_here"
COMPLEX_LLM="gemini/gemini-2.5-pro"

TELEGRAM_BOT_TOKEN="your_telegram_bot_token_here"
TELEGRAM_ALLOWED_USER_IDS="your_telegram_user_id_here"
MASTER_AI_MODEL_ID="3"

# === Alfredo API Server ===
# Port for the REST API (used by external app SDK)
ALFREDO_API_PORT=8000

# === Ollama Cloud / Remote ===
# If using Ollama Cloud or a remote server, specify the base URL and API key.
# OLLAMA_API_BASE="https://api.ollama.com"
# OLLAMA_API_KEY="ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAID9ZiYv7xdytcxCe3gQp9P7e7aSIm3pFOYc2OIIk9G2k"

# === External App Credentials (examples) ===
# These are referenced by name in the 'apps' table.
# When you register an app, set db_env_key="MY_APP_DB_URL" and
# the tool will read os.getenv("MY_APP_DB_URL") at runtime.
#
# MY_APP_DB_URL="sqlite:///path/to/app_database.db"
# MY_APP_DB_URL="postgresql://user:password@localhost:5432/my_app_db"
# MY_APP_API_KEY="sk-your-app-api-key-here"
